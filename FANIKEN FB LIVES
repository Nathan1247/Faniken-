<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Faniken's FB Lives - Football Match Center</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700;800&display=swap');
        
        body {
            font-family: 'Inter', sans-serif;
            background-color: #0f172a;
            color: #f1f5f9;
        }

        .glass-card {
            background: rgba(30, 41, 59, 0.7);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.1);
        }

        .pitch-green {
            background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
        }

        .pulse {
            animation: pulse-animation 2s infinite;
        }

        @keyframes pulse-animation {
            0% { transform: scale(1); opacity: 1; }
            50% { transform: scale(1.1); opacity: 0.7; }
            100% { transform: scale(1); opacity: 1; }
        }

        .custom-scrollbar::-webkit-scrollbar {
            width: 6px;
        }
        .custom-scrollbar::-webkit-scrollbar-thumb {
            background: #334155;
            border-radius: 10px;
        }
    </style>
</head>
<body class="min-h-screen flex flex-col">

    <!-- Navigation -->
    <nav class="sticky top-0 z-50 glass-card px-6 py-4 flex justify-between items-center border-b border-slate-800">
        <div class="flex items-center gap-2">
            <div class="w-10 h-10 pitch-green rounded-full flex items-center justify-center shadow-lg shadow-green-500/20">
                <i class="fas fa-futbol text-white text-xl"></i>
            </div>
            <h1 class="text-xl font-extrabold tracking-tighter uppercase">Faniken's <span class="text-green-500">FB Lives</span></h1>
        </div>
        <div class="hidden md:flex gap-8 font-medium text-sm text-slate-400">
            <a href="#" class="text-white hover:text-green-400 transition">Home</a>
            <a href="#live" class="hover:text-green-400 transition">Live Scores</a>
            <a href="#watch" class="hover:text-green-400 transition">Watch Match</a>
            <a href="#news" class="hover:text-green-400 transition">News</a>
        </div>
        <div class="flex items-center gap-4">
            <button class="bg-green-500 hover:bg-green-600 text-slate-900 font-bold py-2 px-5 rounded-full text-xs transition-all shadow-lg shadow-green-500/30">
                SIGN IN
            </button>
        </div>
    </nav>

    <main class="flex-grow container mx-auto px-4 py-8">
        <!-- Hero Section / Live Now Banner -->
        <section class="mb-12">
            <div class="relative overflow-hidden rounded-3xl p-8 md:p-12 pitch-green shadow-2xl">
                <div class="relative z-10 grid md:grid-cols-2 items-center gap-8">
                    <div>
                        <span class="inline-block bg-white/20 text-white text-[10px] font-bold px-3 py-1 rounded-full mb-4 uppercase tracking-widest">Featured Match</span>
                        <h2 class="text-4xl md:text-5xl font-black text-white mb-6 leading-tight">UCL Quarter Finals: Real Madrid vs Man City</h2>
                        <div class="flex items-center gap-4 mb-8">
                            <div class="flex items-center gap-2 bg-red-600 text-white px-3 py-1 rounded-md text-xs font-bold uppercase">
                                <span class="w-2 h-2 bg-white rounded-full pulse"></span> Live
                            </div>
                            <span class="text-white/80 font-medium">85th Minute</span>
                        </div>
                        <button onclick="scrollToWatch()" class="bg-slate-900 text-white px-8 py-4 rounded-2xl font-bold hover:scale-105 transition-transform flex items-center gap-3">
                            <i class="fas fa-play"></i> Watch Now
                        </button>
                    </div>
                    <div class="flex justify-center md:justify-end items-center gap-4">
                        <div class="text-center">
                            <img src="https://upload.wikimedia.org/wikipedia/en/thumb/5/56/Real_Madrid_CF.svg/1200px-Real_Madrid_CF.svg.png" class="w-24 h-24 mb-4 drop-shadow-xl" alt="Real Madrid">
                            <p class="font-black text-3xl">3</p>
                        </div>
                        <div class="text-2xl font-black text-white/50">VS</div>
                        <div class="text-center">
                            <img src="https://upload.wikimedia.org/wikipedia/en/thumb/e/eb/Manchester_City_FC_badge.svg/1200px-Manchester_City_FC_badge.svg.png" class="w-24 h-24 mb-4 drop-shadow-xl" alt="Man City">
                            <p class="font-black text-3xl">3</p>
                        </div>
                    </div>
                </div>
                <!-- Abstract Design Elements -->
                <div class="absolute top-0 right-0 w-64 h-64 bg-white/10 rounded-full blur-3xl -mr-32 -mt-32"></div>
            </div>
        </section>

        <div class="grid lg:grid-cols-3 gap-8">
            <!-- Left Column: Live Scores & Fixtures -->
            <div class="lg:col-span-2 space-y-8">
                <section id="live">
                    <div class="flex justify-between items-end mb-6">
                        <h3 class="text-2xl font-bold">Match Center</h3>
                        <div class="flex gap-2 text-xs">
                            <button class="px-4 py-2 rounded-lg bg-green-500 text-slate-900 font-bold">ALL</button>
                            <button class="px-4 py-2 rounded-lg glass-card hover:bg-slate-800 transition">LIVE</button>
                            <button class="px-4 py-2 rounded-lg glass-card hover:bg-slate-800 transition">FINISHED</button>
                        </div>
                    </div>

                    <!-- League Header -->
                    <div class="mb-4">
                        <div class="flex items-center gap-2 mb-4 text-slate-400 text-sm font-semibold uppercase tracking-wider">
                            <i class="fas fa-trophy text-yellow-500"></i> Premier League
                        </div>
                        <div class="space-y-3" id="match-container">
                            <!-- Match Item -->
                            <div class="glass-card rounded-2xl p-4 flex items-center justify-between hover:border-green-500/50 transition cursor-pointer group">
                                <div class="flex items-center gap-6 flex-1">
                                    <div class="w-16 text-center border-r border-slate-700 pr-4">
                                        <p class="text-green-500 font-bold text-sm">74'</p>
                                    </div>
                                    <div class="flex items-center gap-4 flex-1">
                                        <span class="font-bold flex-1 text-right">Arsenal</span>
                                        <img src="https://upload.wikimedia.org/wikipedia/en/thumb/5/53/Arsenal_FC.svg/1200px-Arsenal_FC.svg.png" class="w-8 h-8" alt="Arsenal">
                                        <div class="bg-slate-800 px-3 py-1 rounded-lg font-black flex gap-3 text-lg">
                                            <span>2</span>
                                            <span class="text-slate-600">-</span>
                                            <span>1</span>
                                        </div>
                                        <img src="https://upload.wikimedia.org/wikipedia/en/thumb/c/cc/Chelsea_FC.svg/1200px-Chelsea_FC.svg.png" class="w-8 h-8" alt="Chelsea">
                                        <span class="font-bold flex-1">Chelsea</span>
                                    </div>
                                </div>
                                <div class="ml-6 opacity-0 group-hover:opacity-100 transition">
                                    <button class="text-green-500 bg-green-500/10 p-2 rounded-lg"><i class="fas fa-chart-line"></i></button>
                                </div>
                            </div>
                            
                            <!-- Match Item -->
                            <div class="glass-card rounded-2xl p-4 flex items-center justify-between hover:border-green-500/50 transition cursor-pointer group">
                                <div class="flex items-center gap-6 flex-1">
                                    <div class="w-16 text-center border-r border-slate-700 pr-4">
                                        <p class="text-slate-500 font-bold text-sm">21:00</p>
                                    </div>
                                    <div class="flex items-center gap-4 flex-1">
                                        <span class="font-bold flex-1 text-right text-slate-400">Liverpool</span>
                                        <img src="https://upload.wikimedia.org/wikipedia/en/thumb/0/0c/Liverpool_FC.svg/1200px-Liverpool_FC.svg.png" class="w-8 h-8 opacity-50" alt="Liverpool">
                                        <div class="bg-slate-800 px-3 py-1 rounded-lg font-black flex gap-3 text-lg text-slate-500">
                                            <span>VS</span>
                                        </div>
                                        <img src="https://upload.wikimedia.org/wikipedia/en/thumb/7/7c/Everton_FC_logo.svg/1200px-Everton_FC_logo.svg.png" class="w-8 h-8 opacity-50" alt="Everton">
                                        <span class="font-bold flex-1 text-slate-400">Everton</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                <section id="watch">
                    <h3 class="text-2xl font-bold mb-6">How to Watch Live</h3>
                    <div class="grid md:grid-cols-2 gap-4">
                        <!-- Stream Source Card -->
                        <div class="glass-card rounded-3xl p-6 hover:bg-slate-800 transition">
                            <div class="flex items-center gap-4 mb-4">
                                <div class="w-12 h-12 bg-red-600 rounded-2xl flex items-center justify-center">
                                    <i class="fab fa-youtube text-white text-2xl"></i>
                                </div>
                                <div>
                                    <h4 class="font-bold">FIFA+ Official</h4>
                                    <p class="text-xs text-slate-400">World Cup Qualifiers & Highlights</p>
                                </div>
                            </div>
                            <p class="text-sm text-slate-300 mb-4">Official FIFA platform offering free live streams of specific tournaments and matches globally.</p>
                            <a href="https://www.fifa.com/fifaplus" target="_blank" class="block text-center py-3 bg-slate-700 rounded-xl font-bold text-sm hover:bg-slate-600 transition">Open Official Stream</a>
                        </div>

                        <div class="glass-card rounded-3xl p-6 hover:bg-slate-800 transition">
                            <div class="flex items-center gap-4 mb-4">
                                <div class="w-12 h-12 bg-yellow-500 rounded-2xl flex items-center justify-center">
                                    <i class="fas fa-tv text-slate-900 text-xl"></i>
                                </div>
                                <div>
                                    <h4 class="font-bold">DAZN Sports</h4>
                                    <p class="text-xs text-slate-400">Major European Leagues</p>
                                </div>
                            </div>
                            <p class="text-sm text-slate-300 mb-4">Premier destination for Champions League, Serie A, and La Liga coverage across several regions.</p>
                            <a href="https://www.dazn.com" target="_blank" class="block text-center py-3 bg-slate-700 rounded-xl font-bold text-sm hover:bg-slate-600 transition">Go to DAZN</a>
                        </div>
                    </div>
                </section>
            </div>

            <!-- Right Column: Sidebar -->
            <div class="space-y-8">
                <div class="glass-card rounded-3xl p-6">
                    <h4 class="font-bold mb-4 flex items-center gap-2">
                        <i class="fas fa-fire text-orange-500"></i> Top Scorers
                    </h4>
                    <div class="space-y-4">
                        <div class="flex items-center justify-between">
                            <div class="flex items-center gap-3">
                                <span class="text-slate-500 font-bold w-4">1.</span>
                                <div class="w-8 h-8 rounded-full bg-slate-700 overflow-hidden">
                                    <img src="https://api.dicebear.com/7.x/avataaars/svg?seed=Erling" alt="Player">
                                </div>
                                <span class="text-sm font-semibold">E. Haaland</span>
                            </div>
                            <span class="font-black text-green-400">26</span>
                        </div>
                        <div class="flex items-center justify-between">
                            <div class="flex items-center gap-3">
                                <span class="text-slate-500 font-bold w-4">2.</span>
                                <div class="w-8 h-8 rounded-full bg-slate-700 overflow-hidden">
                                    <img src="https://api.dicebear.com/7.x/avataaars/svg?seed=Salah" alt="Player">
                                </div>
                                <span class="text-sm font-semibold">M. Salah</span>
                            </div>
                            <span class="font-black text-green-400">21</span>
                        </div>
                    </div>
                </div>

                <div class="glass-card rounded-3xl p-6 bg-gradient-to-br from-indigo-900/40 to-transparent">
                    <h4 class="font-bold mb-2">Subscribe to Alerts</h4>
                    <p class="text-xs text-slate-400 mb-4">Never miss a goal from your favorite team.</p>
                    <input type="email" placeholder="email@example.com" class="w-full bg-slate-900/50 border border-slate-700 rounded-xl p-3 text-sm mb-3 focus:outline-none focus:border-green-500">
                    <button class="w-full bg-green-500 text-slate-900 font-bold py-3 rounded-xl hover:bg-green-400 transition">Get Notified</button>
                </div>
            </div>
        </div>
    </main>

    <footer class="glass-card mt-12 py-10 px-6 border-t border-slate-800">
        <div class="container mx-auto grid md:grid-cols-4 gap-8">
            <div class="md:col-span-2">
                <div class="flex items-center gap-2 mb-4">
                    <div class="w-8 h-8 pitch-green rounded-full flex items-center justify-center">
                        <i class="fas fa-futbol text-white text-sm"></i>
                    </div>
                    <h1 class="text-lg font-extrabold uppercase">Faniken's <span class="text-green-500">FB Lives</span></h1>
                </div>
                <p class="text-slate-400 text-sm max-w-sm">
                    Faniken's FB Lives provides real-time updates and legal viewing guides for football fans worldwide. We promote official broadcasting channels to support the sport.
                </p>
            </div>
            <div>
                <h5 class="font-bold mb-4">Leagues</h5>
                <ul class="text-sm text-slate-500 space-y-2">
                    <li><a href="#" class="hover:text-white">Premier League</a></li>
                    <li><a href="#" class="hover:text-white">La Liga</a></li>
                    <li><a href="#" class="hover:text-white">Champions League</a></li>
                    <li><a href="#" class="hover:text-white">Serie A</a></li>
                </ul>
            </div>
            <div>
                <h5 class="font-bold mb-4">Follow Us</h5>
                <div class="flex gap-4">
                    <a href="#" class="text-slate-500 hover:text-white text-xl"><i class="fab fa-twitter"></i></a>
                    <a href="#" class="text-slate-500 hover:text-white text-xl"><i class="fab fa-instagram"></i></a>
                    <a href="#" class="text-slate-500 hover:text-white text-xl"><i class="fab fa-youtube"></i></a>
                </div>
            </div>
        </div>
        <div class="text-center mt-12 pt-8 border-t border-slate-800 text-slate-600 text-xs">
            © 2026 Faniken's FB Lives. All Rights Reserved. Not affiliated with any official club.
        </div>
    </footer>

    <script>
        function scrollToWatch() {
            document.getElementById('watch').scrollIntoView({ behavior: 'smooth' });
        }

        // Mock interaction for match list
        document.querySelectorAll('#match-container > div').forEach(item => {
            item.addEventListener('click', () => {
                const home = item.querySelector('span:first-of-type').innerText;
                const away = item.querySelector('span:last-of-type').innerText;
                
                // For demonstration: show custom toast instead of alert
                showMatchToast(`Detailed stats for ${home} vs ${away} coming soon!`);
            });
        });

        function showMatchToast(msg) {
            const toast = document.createElement('div');
            toast.className = 'fixed bottom-8 left-1/2 -translate-x-1/2 bg-green-500 text-slate-900 px-6 py-3 rounded-full font-bold shadow-2xl z-50 transform translate-y-20 transition-all duration-300';
            toast.innerText = msg;
            document.body.appendChild(toast);
            
            setTimeout(() => {
                toast.classList.remove('translate-y-20');
            }, 100);

            setTimeout(() => {
                toast.classList.add('translate-y-20');
                setTimeout(() => toast.remove(), 300);
            }, 3000);
        }
    </script>
</body>
</html>
